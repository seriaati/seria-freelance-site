---
import { Image } from 'astro:assets';
import { getAlternateLocale, getLocalePath } from '../i18n';
import type { Translations } from '../i18n/en';
import logoBlack from '../assets/logoBlack.png';
import logoWhite from '../assets/logoWhite.png';

interface Props {
  locale: string;
  t: Translations;
}

const { locale, t } = Astro.props;
const altLocale = getAlternateLocale(locale);
const altLabel = altLocale === 'zh-TW' ? '中文' : 'EN';

const currentPath = Astro.url.pathname;
const stripLocale = (path: string) => path.replace(/^\/(en)/, '') || '/';
const basePath = stripLocale(currentPath);
const altPath = getLocalePath(altLocale, basePath);

const navLinks = [
  { href: getLocalePath(locale, '/'), label: t.nav.home },
  { href: getLocalePath(locale, '/about'), label: t.nav.about },
  { href: getLocalePath(locale, '/projects'), label: t.nav.projects },
];
---

<header class="nav-header">
  <div class="container nav-inner">
    <a href={getLocalePath(locale, '/')} class="wordmark" aria-label="Seria — Home">
      <Image src={logoBlack} alt="Seria" height={40} class="logo-light" />
      <Image src={logoWhite} alt="Seria" height={40} class="logo-dark" />
    </a>

    <nav class="nav-links" aria-label="Main navigation">
      {navLinks.map(link => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
    </nav>

    <div class="nav-actions">
      <a href={altPath} class="lang-switch" aria-label={`Switch to ${altLocale}`}>
        {altLabel}
      </a>
      <button class="theme-toggle" aria-label="Toggle dark mode" id="themeToggle">
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <a href={`${getLocalePath(locale, '/about')}#contact`} class="nav-cta">
        {t.nav.contact}
      </a>
    </div>

    <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="mobile-menu" aria-hidden="true">
    <nav class="mobile-nav">
      {navLinks.map(link => (
        <a href={link.href} class="mobile-nav-link">{link.label}</a>
      ))}
      <a href={`${getLocalePath(locale, '/about')}#contact`} class="mobile-nav-link">{t.nav.contact}</a>
    </nav>
    <a href={altPath} class="mobile-lang-switch">{altLabel}</a>
  </div>
</header>

<style>
  .nav-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: color-mix(in oklch, var(--paper) 92%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--rule);
    transition: border-color 0.3s var(--ease-out-quart);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    height: 4rem;
  }

  .wordmark {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .wordmark img {
    display: block;
    height: 40px;
    width: auto;
  }

  .logo-dark {
    display: none;
  }

  [data-theme="dark"] .logo-light {
    display: none;
  }

  [data-theme="dark"] .logo-dark {
    display: block;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .logo-light {
      display: none;
    }

    :root:not([data-theme="light"]) .logo-dark {
      display: block;
    }
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    margin-left: auto;
  }

  .nav-link {
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--ink-muted);
    letter-spacing: 0.02em;
    transition: color 0.2s;
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--ink);
    transition: width 0.3s var(--ease-out-quart);
  }

  .nav-link:hover {
    color: var(--ink);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .lang-switch {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--ink-faint);
    letter-spacing: 0.08em;
    transition: color 0.2s;
  }

  .lang-switch:hover {
    color: var(--ink);
  }

  .theme-toggle {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--rule);
    color: var(--ink-muted);
    cursor: pointer;
    padding: 0.35em;
    width: 2rem;
    height: 2rem;
    transition: color 0.2s, border-color 0.2s;
  }

  .theme-toggle:hover {
    color: var(--ink);
    border-color: var(--ink-faint);
  }

  .icon-sun,
  .icon-moon {
    position: absolute;
    transition: opacity 0.2s, transform 0.3s var(--ease-out-quart);
  }

  :root:not([data-theme="dark"]) .icon-moon,
  [data-theme="light"] .icon-moon {
    opacity: 0;
    transform: rotate(-30deg) scale(0.8);
  }

  :root:not([data-theme="dark"]) .icon-sun,
  [data-theme="light"] .icon-sun {
    opacity: 1;
    transform: none;
  }

  [data-theme="dark"] .icon-sun {
    opacity: 0;
    transform: rotate(30deg) scale(0.8);
  }

  [data-theme="dark"] .icon-moon {
    opacity: 1;
    transform: none;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .icon-sun {
      opacity: 0;
      transform: rotate(30deg) scale(0.8);
    }

    :root:not([data-theme="light"]) .icon-moon {
      opacity: 1;
      transform: none;
    }
  }

  .nav-cta {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--paper);
    background: var(--ink);
    padding: 0.4em 1em;
    letter-spacing: 0.02em;
    transition: opacity 0.2s, background-color 0.25s ease, color 0.25s ease;
  }

  .nav-cta:hover {
    opacity: 0.75;
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }

  .menu-toggle span {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--ink);
    transition: transform 0.3s var(--ease-out-quart), opacity 0.3s;
  }

  .menu-toggle[aria-expanded="true"] span:first-child {
    transform: translateY(6px) rotate(45deg);
  }

  .menu-toggle[aria-expanded="true"] span:last-child {
    transform: translateY(-6px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    padding: var(--space-lg) var(--gutter) var(--space-xl);
    border-top: 1px solid var(--rule);
  }

  .mobile-menu.open {
    display: block;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .mobile-nav-link {
    font-size: var(--text-xl);
    font-family: var(--font-display);
    font-weight: 400;
    color: var(--ink);
  }

  .mobile-lang-switch {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--ink-faint);
    letter-spacing: 0.08em;
  }

  @media (max-width: 768px) {
    .nav-links,
    .nav-actions {
      display: none;
    }

    .menu-toggle {
      display: flex;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.menu-toggle') as HTMLButtonElement;
  const mobileMenu = document.querySelector('.mobile-menu') as HTMLElement;

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    mobileMenu.setAttribute('aria-hidden', String(isOpen));
    mobileMenu.classList.toggle('open', !isOpen);
  });

  const themeToggle = document.getElementById('themeToggle') as HTMLButtonElement;

  function getEffectiveTheme(): string {
    const saved = localStorage.getItem('theme');
    if (saved) return saved;
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  themeToggle?.addEventListener('click', () => {
    const current = getEffectiveTheme();
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });
</script>
