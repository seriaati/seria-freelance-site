---
import { getLocalePath } from '../i18n';
import type { Translations } from '../i18n/en';
import { getFeaturedProjects, getProjectField } from '../data/projects';

interface Props {
  locale: string;
  t: Translations;
}

const { locale, t } = Astro.props;
const featured = getFeaturedProjects();
---

<section class="projects-section">
  <div class="container">
    <div class="projects-header">
      <span class="section-label">{t.projects.sectionLabel}</span>
      <h2 class="projects-heading">{t.projects.heading}</h2>
    </div>

    <ol class="projects-list">
      {featured.map((project, i) => (
        <li class="project-item">
          <span class="project-number">0{i + 1}</span>
          <div class="project-body">
            <div class="project-meta">
              <span class="project-category">{getProjectField(project, 'category', locale)}</span>
              <span class="project-year">{project.year}</span>
            </div>
            <h3 class="project-title">{getProjectField(project, 'title', locale)}</h3>
            <p class="project-desc">{getProjectField(project, 'description', locale)}</p>
            {project.tags && project.tags.length > 0 && (
              <ul class="project-tags" aria-label="Technologies used">
                {project.tags.map(tag => (
                  <li class="project-tag">{tag}</li>
                ))}
              </ul>
            )}
          </div>
          {project.thumbnail && (
            <div class="project-thumbnail">
              <img src={project.thumbnail} alt={getProjectField(project, 'title', locale)} loading="lazy" />
            </div>
          )}
        </li>
      ))}
    </ol>

    <div class="projects-footer">
      <a href={getLocalePath(locale, '/projects')} class="projects-cta">
        {t.projects.cta}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .projects-section {
    padding-block: var(--space-3xl);
    border-top: 1px solid var(--rule);
  }

  .projects-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-2xl);
  }

  .projects-heading {
    font-size: var(--text-3xl);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .projects-list {
    list-style: none;
    border-top: 1px solid var(--rule);
  }

  .project-item {
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    gap: var(--space-lg);
    padding-block: var(--space-xl);
    border-bottom: 1px solid var(--rule);
    transition: background-color 0.3s var(--ease-out-quart);
    cursor: default;
    align-items: start;
  }

  .project-item:hover {
    background-color: var(--paper-warm);
  }

  .project-item:hover .project-title {
    transform: translateX(4px);
  }

  .project-number {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: var(--ink-faint);
    padding-top: 0.3em;
    font-weight: 300;
    letter-spacing: 0.05em;
  }

  .project-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .project-category {
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .project-year {
    font-size: var(--text-sm);
    color: var(--ink-faint);
  }

  .project-title {
    font-size: var(--text-2xl);
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: var(--ink);
    transition: transform 0.3s var(--ease-out-quart);
  }

  .project-desc {
    font-size: var(--text-base);
    color: var(--ink-muted);
    line-height: 1.65;
    max-width: 560px;
    font-weight: 300;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    list-style: none;
    margin-top: var(--space-xs);
  }

  .project-tag {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
    background: var(--paper-warm);
    border: 1px solid var(--rule);
    padding: 0.2em 0.65em;
  }

  .projects-footer {
    margin-top: var(--space-xl);
    display: flex;
    justify-content: flex-end;
  }

  .projects-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--ink);
    letter-spacing: 0.02em;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 2px;
    transition: gap 0.3s var(--ease-out-quart), opacity 0.2s;
  }

  .projects-cta:hover {
    gap: 0.75em;
    opacity: 0.7;
  }

  .project-thumbnail {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
    border: 1px solid var(--rule);
    overflow: hidden;
  }

  .project-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 480px) {
    .project-item {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
    }

    .project-number {
      display: none;
    }

    .project-thumbnail {
      width: 64px;
      height: 64px;
    }
  }
</style>
