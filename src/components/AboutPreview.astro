---
import { getLocalePath } from '../i18n';
import type { Translations } from '../i18n/en';

interface Props {
  locale: string;
  t: Translations;
}

const { locale, t } = Astro.props;
---

<section class="about-preview">
  <div class="container about-inner">
    <div class="about-rule-col" aria-hidden="true">
      <span class="section-label about-label">{t.about.sectionLabel}</span>
      <div class="vertical-rule"></div>
    </div>

    <div class="about-content">
      <h2 class="about-heading">{t.about.heading}</h2>
      <p class="about-body">{t.about.body}</p>
      <a href={getLocalePath(locale, '/about')} class="about-cta">
        {t.about.cta}
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2.5 7h9M8 3.5l3.5 3.5L8 10.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .about-preview {
    padding-block: var(--space-3xl);
    border-top: 1px solid var(--rule);
  }

  .about-inner {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  .about-rule-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
    padding-top: 0.25em;
  }

  .about-label {
    writing-mode: horizontal-tb;
  }

  .vertical-rule {
    width: 1px;
    height: 80px;
    background: var(--rule);
    margin-left: 2px;
  }

  .about-content {
    max-width: 640px;
  }

  .about-heading {
    font-size: var(--text-3xl);
    font-weight: 300;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-lg);
    color: var(--ink);
  }

  .about-body {
    font-size: var(--text-lg);
    color: var(--ink-muted);
    line-height: 1.7;
    margin-bottom: var(--space-xl);
    font-weight: 300;
  }

  .about-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--ink);
    letter-spacing: 0.02em;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 2px;
    transition: gap 0.3s var(--ease-out-quart), opacity 0.2s;
  }

  .about-cta:hover {
    gap: 0.75em;
    opacity: 0.7;
  }

  @media (max-width: 640px) {
    .about-inner {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .about-rule-col {
      flex-direction: row;
      align-items: center;
    }

    .vertical-rule {
      width: 40px;
      height: 1px;
    }
  }
</style>
