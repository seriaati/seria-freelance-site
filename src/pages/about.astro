---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import { useTranslations, getLocalePath } from "../i18n";
import avatar from "../assets/avatar.png";

const locale = "zh-TW";
const t = useTranslations(locale);
const p = t.about.page;
---

<Layout
  locale={locale}
  title={p.title}
  description={p.description}
>
  <div class="about-page">
    <div class="container">
      <header class="page-header">
        <span class="section-label">{t.about.sectionLabel}</span>
        <h1 class="page-title">{p.pageTitle}</h1>
      </header>

      <div class="about-grid">
        <div class="about-main">
          <p class="about-lead">{p.lead}</p>

          <div class="about-prose">
            <p>{p.prose1}</p>
            <p>{p.prose2}</p>
            <p>{p.prose3}</p>
          </div>

        </div>

        <aside class="about-sidebar">
          <div class="avatar-block">
            <Image
              src={avatar}
              alt="Seria"
              width={220}
              height={220}
              class="avatar"
            />
          </div>
          <div class="sidebar-block">
            <h3 class="sidebar-label">{p.sidebarBasedIn}</h3>
            <p>{p.sidebarBasedInValue}</p>
          </div>
          <div class="sidebar-block">
            <h3 class="sidebar-label">{p.sidebarLanguages}</h3>
            <p set:html={p.sidebarLanguagesValue.replace('\n', '<br />')} />
          </div>
        </aside>
      </div>

      <div class="contact-section" id="contact">
        <div class="contact-section-inner">
          <div class="contact-text">
            <span class="section-label">{p.contactLabel}</span>
            <h2 class="contact-heading">{p.contactHeading}</h2>
            <p class="contact-desc">{p.contactDesc}</p>
          </div>
          <div class="contact-actions">
            <a
              href="mailto:hi@seria.moe"
              class="contact-btn contact-btn-primary"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 16 16"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M2 4h12v9H2V4z"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linejoin="round"></path>
                <path
                  d="M2 4l6 5 6-5"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
              Email
            </a>
            <a
              href="https://discord.com/users/410036441129943050"
              class="contact-btn contact-btn-ghost"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
              </svg>
              Discord
            </a>
            <a
              href="https://line.me/ti/p/O4Y5UUJSqK"
              class="contact-btn contact-btn-ghost"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63.349 0 .631.285.631.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
              </svg>
              LINE
            </a>
            <a
              href="https://shopee.tw/seriaati"
              class="contact-btn contact-btn-ghost"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.5 7.5h-1.25c0-1.795-1.455-3.25-3.25-3.25S8.75 7.705 8.75 9.5H7.5c0-2.481 2.019-4.5 4.5-4.5s4.5 2.019 4.5 4.5zm1.25 1v6.5a1 1 0 0 1-1 1h-9.5a1 1 0 0 1-1-1V10.5h11.5z"/>
              </svg>
              Shopee
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .about-page {
    padding-top: calc(4rem + var(--space-2xl));
    padding-bottom: var(--space-3xl);
  }

  .page-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--rule);
  }

  .page-title {
    font-size: var(--text-4xl);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: var(--space-2xl);
    align-items: start;
    margin-bottom: var(--space-2xl);
  }

  .about-lead {
    font-size: var(--text-xl);
    font-family: var(--font-display);
    font-weight: 300;
    line-height: 1.5;
    color: var(--ink);
    margin-bottom: var(--space-xl);
    font-style: italic;
  }

  .about-prose {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
  }

  .about-prose p {
    font-size: var(--text-base);
    color: var(--ink-muted);
    line-height: 1.75;
    font-weight: 300;
  }

  .about-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    padding-top: 0.25em;
  }

  .avatar-block {
    width: 100%;
  }

  .avatar {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1;
    object-fit: cover;
    filter: grayscale(20%);
    border-radius: 6px;
  }

  .sidebar-block {
    border-top: 1px solid var(--rule);
    padding-top: var(--space-md);
  }

  .sidebar-label {
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 0.4em;
    font-family: var(--font-body);
  }

  .sidebar-block p {
    font-size: var(--text-sm);
    color: var(--ink-muted);
    line-height: 1.6;
  }

  .contact-section {
    margin-top: var(--space-3xl);
    border-top: 1px solid var(--rule);
    padding-top: var(--space-2xl);
  }

  .contact-section-inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-2xl);
  }

  .contact-heading {
    font-size: var(--text-3xl);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-top: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .contact-desc {
    font-size: var(--text-base);
    color: var(--ink-muted);
    font-weight: 300;
    line-height: 1.6;
  }

  .contact-actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-shrink: 0;
  }

  .contact-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.02em;
    white-space: nowrap;
    transition: opacity 0.2s;
  }

  .contact-btn-primary {
    color: var(--paper);
    background: var(--ink);
    padding: 0.75em 1.5em;
  }

  .contact-btn-primary:hover {
    opacity: 0.8;
  }

  .contact-btn-ghost {
    color: var(--ink-muted);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 2px;
    transition:
      color 0.2s,
      border-color 0.2s;
  }

  .contact-btn-ghost:hover {
    color: var(--ink);
    border-color: var(--ink);
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
    }

    .about-sidebar {
      order: -1;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
    }

    .contact-section-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .contact-actions {
      flex-wrap: wrap;
    }
  }
</style>
